EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# Production mobile builds: URL where Expo API routes are hosted (EAS Hosting).
# Leave empty for local dev (uses relative /api/... paths).
# Example: https://duolingo-clone.expo.app
EXPO_PUBLIC_API_URL=

POSTHOG_PROJECT_TOKEN=your_posthog_project_token
POSTHOG_HOST=https://your-posthog-host
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# Vision Agent service (Python) — used by the agent-session API route on the SERVER.
# Local dev: http://localhost:8000 or http://192.168.x.x:8000
# Production: https://your-vision-agent.up.railway.app
VISION_AGENT_URL=http://localhost:8000

# OpenAI API key — required only for the vision-agent Python service
# Add this to vision-agent/.env (not here); listed here for discoverability
# OPENAI_API_KEY=your_openai_api_key
